# ── App ──────────────────────────────────────────────────────────────────
APP_NAME="Shopify Analytics Platform"
DEBUG=false
SECRET_KEY=change_me_to_a_long_random_string

# ── Database ──────────────────────────────────────────────────────────────
# asyncpg driver required (async FastAPI) — psycopg2 used by Celery workers
DATABASE_URL=postgresql+asyncpg://postgres:Om%40885687@localhost:5432/shop_analytics
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# ── Shopify App Credentials ───────────────────────────────────────────────
# Found in your Partner Dashboard → App → API credentials
SHOPIFY_API_KEY=a102e6b43153606f2fd4b60705d02ef5
SHOPIFY_API_SECRET=c7502c6455b4bd13578d0a29e9be6bd1
SHOPIFY_API_VERSION=2024-07
SHOPIFY_SCOPES=read_customers,read_orders,read_products

# ── App URL (used for OAuth redirect + webhook callback URLs) ─────────────
# In dev: use ngrok or Cloudflare Tunnel to expose localhost
APP_BASE_URL=https://your-ngrok-url.ngrok.io

# ── Redis ─────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── Webhook settings ──────────────────────────────────────────────────────
WEBHOOK_MAX_RETRIES=5
WEBHOOK_RETRY_BACKOFF=60

# ── Bulk sync settings ────────────────────────────────────────────────────
BULK_POLL_INTERVAL=10
BULK_MAX_WAIT=3600

# ── Currency ──────────────────────────────────────────────────────────────
DEFAULT_CURRENCY=USD
